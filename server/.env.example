PORT=5000
CLIENT_URL=http://localhost:3000
MONGODB_URI=mongodb://localhost:27017/clipbridge
# Optional: MongoDB Atlas
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/clipbridge

# File upload limits
MAX_FILE_SIZE=50
# MB - e.g. 50 = 50MB

# Auto-expiry defaults (in minutes)
DEFAULT_ROOM_EXPIRY=60
# 60 = 1 hour, 1440 = 24 hours

# Cleanup interval (in minutes)
CLEANUP_INTERVAL=5
